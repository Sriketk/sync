{
  "name": "sync",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "ready": "vp check && vp run -r build",
    "dev": "vp run web#dev",
    "build": "vp run -r build",
    "check": "vp check"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.5",
      "onFail": "download"
    }
  }
}
